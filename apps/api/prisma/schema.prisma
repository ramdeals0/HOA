generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  BOARD
  MANAGER
  MEMBER
  RESIDENT
}

enum TenantUserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClassifiedStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  OVERDUE
  VOID
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum DocumentVisibility {
  PUBLIC
  MEMBERS
  BOARD
  FINANCIAL
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BlastStatus {
  QUEUED
  SENDING
  SENT
  FAILED
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  phone           String?
  isPlatformOwner Boolean  @default(false) @map("is_platform_owner")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenantUsers           TenantUser[]
  properties            Property[]
  membershipApplications MembershipApplication[] @relation("ApplicantUser")
  reviewedApplications  MembershipApplication[] @relation("ReviewedBy")
  newsPosts             NewsPost[]
  blastMessages         BlastMessage[]
  classifiedListings    ClassifiedListing[]
  reviewedClassifieds   ClassifiedListing[]     @relation("ClassifiedReviewer")
  invoices              Invoice[]
  payments              Payment[]
  documents             Document[]
  maintenanceRequests   MaintenanceRequest[]    @relation("Requester")
  assignedMaintenance   MaintenanceRequest[]    @relation("Assignee")

  @@map("users")
}

model Tenant {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  timezone            String   @default("America/Chicago")
  locale              String   @default("en-US")
  address             String?
  state               String?
  primaryContactEmail String   @map("primary_contact_email")
  isActive            Boolean  @default(true) @map("is_active")
  plan                Plan     @default(FREE)
  logoUrl             String?  @map("logo_url")
  primaryColor        String   @default("#2563eb") @map("primary_color")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  settings              TenantSettings?
  tenantUsers           TenantUser[]
  properties            Property[]
  membershipApplications MembershipApplication[]
  newsPosts             NewsPost[]
  blastMessages         BlastMessage[]
  classifiedListings    ClassifiedListing[]
  invoices              Invoice[]
  payments              Payment[]
  documents             Document[]
  maintenanceRequests   MaintenanceRequest[]

  @@index([slug])
  @@map("tenants")
}

model TenantSettings {
  id                  String   @id @default(uuid())
  tenantId            String   @unique @map("tenant_id")
  monthlyDuesCents    Int      @default(15000) @map("monthly_dues_cents")
  annualDuesCents     Int      @default(180000) @map("annual_dues_cents")
  stripePublicKey     String?  @map("stripe_public_key")
  stripeSecretKey     String?  @map("stripe_secret_key")
  stripeWebhookSecret String?  @map("stripe_webhook_secret")
  lastStripeEventAt   DateTime? @map("last_stripe_event_at")
  lastEmailSentAt     DateTime? @map("last_email_sent_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model TenantUser {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  userId    String           @map("user_id")
  role      Role
  status    TenantUserStatus @default(ACTIVE)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_users")
}

model Property {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  ownerId      String?   @map("owner_id")
  street       String
  lotNumber    String?   @map("lot_number")
  city         String    @default("")
  state        String    @default("")
  zip          String    @default("")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner               User?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  maintenanceRequests MaintenanceRequest[]

  @@index([tenantId])
  @@index([ownerId])
  @@map("properties")
}

model MembershipApplication {
  id              String            @id @default(uuid())
  tenantId        String            @map("tenant_id")
  applicantUserId String?           @map("applicant_user_id")
  firstName       String            @map("first_name")
  lastName        String            @map("last_name")
  email           String
  phone           String?
  propertyAddress String            @map("property_address")
  lotNumber       String?           @map("lot_number")
  message         String?
  status          ApplicationStatus @default(PENDING)
  reviewedById    String?           @map("reviewed_by_id")
  reviewedAt      DateTime?         @map("reviewed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applicantUser User?  @relation("ApplicantUser", fields: [applicantUserId], references: [id], onDelete: SetNull)
  reviewedBy    User?  @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@map("membership_applications")
}

model NewsPost {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  authorId    String   @map("author_id")
  title       String
  body        String
  isPublic    Boolean  @default(true) @map("is_public")
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isPublic, isPublished])
  @@map("news_posts")
}

model BlastMessage {
  id             String      @id @default(uuid())
  tenantId       String      @map("tenant_id")
  authorId       String      @map("author_id")
  subject        String
  body           String
  audience       String
  audienceFilter Json?       @map("audience_filter")
  status         BlastStatus @default(QUEUED)
  sentCount      Int         @default(0) @map("sent_count")
  failureCount   Int         @default(0) @map("failure_count")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("blast_messages")
}

model ClassifiedListing {
  id           String           @id @default(uuid())
  tenantId     String           @map("tenant_id")
  authorId     String           @map("author_id")
  title        String
  description  String
  category     String
  priceCents   Int?             @map("price_cents")
  contactEmail String?          @map("contact_email")
  contactPhone String?          @map("contact_phone")
  status       ClassifiedStatus @default(PENDING)
  reviewedById String?          @map("reviewed_by_id")
  reviewedAt   DateTime?        @map("reviewed_at")
  deletedAt    DateTime?        @map("deleted_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author     User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("ClassifiedReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@map("classified_listings")
}

model Invoice {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  userId      String        @map("user_id")
  amountCents Int           @map("amount_cents")
  description String
  periodStart DateTime      @map("period_start")
  periodEnd   DateTime      @map("period_end")
  dueDate     DateTime      @map("due_date")
  status      InvoiceStatus @default(OPEN)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@map("invoices")
}

model Payment {
  id                    String        @id @default(uuid())
  tenantId              String        @map("tenant_id")
  invoiceId             String        @map("invoice_id")
  userId                String        @map("user_id")
  amountCents           Int           @map("amount_cents")
  status                PaymentStatus @default(PENDING)
  stripeSessionId       String?       @map("stripe_session_id")
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
  @@index([userId])
  @@map("payments")
}

model Document {
  id          String             @id @default(uuid())
  tenantId    String             @map("tenant_id")
  uploadedById String            @map("uploaded_by_id")
  title       String
  description String?
  fileUrl     String             @map("file_url")
  visibility  DocumentVisibility @default(MEMBERS)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([visibility])
  @@map("documents")
}

model MaintenanceRequest {
  id           String              @id @default(uuid())
  tenantId     String              @map("tenant_id")
  requesterId  String              @map("requester_id")
  propertyId   String?             @map("property_id")
  assignedToId String?             @map("assigned_to_id")
  title        String
  description  String
  status       MaintenanceStatus   @default(OPEN)
  priority     MaintenancePriority @default(MEDIUM)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requester  User      @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  assignedTo User?     @relation("Assignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@map("maintenance_requests")
}
