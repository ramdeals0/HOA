{
  "name": "@hoa/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build:sw": "esbuild src/sw/service-worker.ts --outfile=public/sw.js --format=iife --target=es2020",
    "generate:icons": "node scripts/generate-pwa-icons.mjs",
    "build": "pnpm generate:icons && pnpm build:sw && next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint"
  },
  "dependencies": {
    "@hoa/shared": "workspace:*",
    "@tanstack/react-query": "^5.62.8",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "^14.2.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.49",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
