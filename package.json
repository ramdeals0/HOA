{
  "name": "hoa-saas",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "pnpm --filter @hoa/api db:migrate",
    "db:seed": "pnpm --filter @hoa/api db:seed",
    "db:generate": "pnpm --filter @hoa/api db:generate",
    "railway:deploy": "bash scripts/railway-deploy.sh",
    "railway:plan": "npx @railway/cli config plan",
    "railway:apply": "npx @railway/cli config apply"
  },
  "devDependencies": {
    "railway": "3.4.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
