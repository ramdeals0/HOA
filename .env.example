# Database
DATABASE_URL="postgresql://hoa:hoa_dev_password@localhost:5432/hoa_saas?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"
COOKIE_NAME="hoa_session"
NODE_ENV="development"

# API (Railway injects PORT automatically)
API_PORT=4000
API_URL="https://your-api.up.railway.app"
WEB_URL="https://your-web.up.railway.app"
CORS_ORIGIN="https://your-web.up.railway.app"
COOKIE_CROSS_ORIGIN="true"

# Stripe (platform fallback / test mode)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLIC_KEY="pk_test_..."

# Email (nodemailer)
EMAIL_PROVIDER="memory"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@hoa-saas.example.com"

# Platform owner (SaaS admin)
PLATFORM_OWNER_EMAIL="platform@hoa-saas.example.com"
